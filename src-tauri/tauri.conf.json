{
    "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
    "productName": "AEnhance",
    "version": "0.1.0",
    "identifier": "com.jonathanlamela.aenhance",
    "build": {
        "frontendDist": "../dist",
        "devUrl": "http://localhost:5173",
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build"
    },
    "app": {
        "windows": [
            {
                "label": "main",
                "title": "AEnhance",
                "width": 1320,
                "height": 880,
                "minWidth": 390,
                "minHeight": 740,
                "resizable": true,
                "fullscreen": false,
                "titleBarStyle": "Transparent",
                "hiddenTitle": true
            }
        ],
        "security": {
            "csp": null,
            "assetProtocol": {
                "enable": true,
                "scope": ["$HOME/**", "/tmp/**"]
            }
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "android": {
            "debugApplicationIdSuffix": ".debug"
        },
        "macOS": {
            "minimumSystemVersion": "10.13"
        }
    }
}
